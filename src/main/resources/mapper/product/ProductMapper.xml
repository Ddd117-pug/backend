<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.toyshop.product.mapper.ProductMapper">

    <resultMap id="ProductResultMap" type="com.toyshop.product.entity.Product">
        <id property="id" column="id"/>
        <result property="categoryId" column="category_id"/>
        <result property="brandId" column="brand_id"/>
        <result property="name" column="name"/>
        <result property="subTitle" column="sub_title"/>
        <result property="description" column="description"/>
        <result property="coverUrl" column="cover_url"/>
        <result property="bannerUrls" column="banner_urls"/>
        <result property="detailImageUrls" column="detail_image_urls"/>
        <result property="price" column="price"/>
        <result property="originalPrice" column="original_price"/>
        <result property="stock" column="stock"/>
        <result property="saleCount" column="sale_count"/>
        <result property="material" column="material"/>
        <result property="size" column="size"/>
        <result property="isBlindBox" column="is_blind_box"/>
        <result property="blindBoxInfo" column="blind_box_info"/>
        <result property="styleDesc" column="style_desc"/>
        <result property="blindBoxMode" column="blind_box_mode"/>
        <result property="status" column="status"/>
        <result property="isHot" column="is_hot"/>
        <result property="isNew" column="is_new"/>
        <result property="createdAt" column="created_at"/>
        <result property="updatedAt" column="updated_at"/>
    </resultMap>

    <sql id="BaseColumns">
        id, category_id, brand_id, name, sub_title, description, cover_url, banner_urls, detail_image_urls,
        price, original_price, stock, sale_count, material, size,
        is_blind_box, blind_box_info, style_desc, blind_box_mode, status, is_hot, is_new, created_at, updated_at
    </sql>

    <select id="selectPageList" resultMap="ProductResultMap">
        SELECT <include refid="BaseColumns" />
        FROM product
        WHERE status = 1
        <if test="categoryId != null">
            AND category_id = #{categoryId}
        </if>
        <if test="brandId != null">
            AND brand_id = #{brandId}
        </if>
        ORDER BY created_at DESC, id DESC
    </select>

    <select id="selectHotList" resultMap="ProductResultMap">
        SELECT <include refid="BaseColumns" />
        FROM product
        WHERE status = 1 AND is_hot = 1
        ORDER BY sale_count DESC, id DESC
        LIMIT #{limit}
    </select>

    <select id="selectNewList" resultMap="ProductResultMap">
        SELECT <include refid="BaseColumns" />
        FROM product
        WHERE status = 1 AND is_new = 1
        ORDER BY created_at DESC, id DESC
        LIMIT #{limit}
    </select>

    <select id="selectDetailById" resultMap="ProductResultMap">
        SELECT <include refid="BaseColumns" />
        FROM product
        WHERE id = #{id} AND status = 1
        LIMIT 1
    </select>
</mapper>
